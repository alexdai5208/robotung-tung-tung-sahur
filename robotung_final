#include <ESP32Servo.h>

// global variables for servo stuff
Servo baseServo;
Servo verticalServo;
Servo clawServo;

// SAFE PINS for ESP32
// Pin 3 is RX0 (Serial) and Pin 2 is the onboard LED. Do not use them for servos!
const int baseServoPin = 12;
const int verticalServoPin = 14;
const int clawServoPin = 27;

// global variables for ultrasonic sensor stuff
const int trigPin = 16;
const int echoPin = 17;

void setup() {
  Serial.begin(9600);

  // Allocate hardware timers to ensure this is purely a HARDWARE test, 
  // not a software glitch overlapping the signals.
  ESP32PWM::allocateTimer(0);
  ESP32PWM::allocateTimer(1);
  ESP32PWM::allocateTimer(2);
  ESP32PWM::allocateTimer(3);

  baseServo.setPeriodHertz(50);
  verticalServo.setPeriodHertz(50);
  clawServo.setPeriodHertz(50);

  // base servo setup
  baseServo.attach(baseServoPin);
  verticalServo.attach(verticalServoPin);
  clawServo.attach(clawServoPin);

  // ultrasonic sensor setup
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  Serial.println("--- STARTING SERVO OVERLOAD TEST ---");
  delay(2000); // Give you 2 seconds to open the Serial Monitor
}

void loop() {
  // 1. AGGRESSIVE SWEEP OUT
  // Moving in increments of 5 degrees with a short delay draws heavy current
  for (int pos = 0; pos <= 180; pos += 5) {
    baseServo.write(pos);
    verticalServo.write(180 - pos); // Opposing movement!
    clawServo.write(pos);
    delay(250);
  }

  // 2. SENSOR HEARTBEAT CHECK
  // If the board lost power during the sweep, it will never reach this code
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  
  float duration = pulseIn(echoPin, HIGH);
  float distance = (duration * .0343) / 2;

  Serial.print("Sweep Out Complete. Sensor Distance: ");
  Serial.println(distance);

  // 3. AGGRESSIVE SWEEP IN
  for (int pos = 180; pos >= 0; pos -= 5) {
    baseServo.write(pos);
    verticalServo.write(180 - pos);
    clawServo.write(pos);
    delay(250);
  }

  Serial.println("Sweep In Complete. If this prints, your power supply is strong enough!\n");
}
